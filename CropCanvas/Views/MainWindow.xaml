<Window x:Class="CropCanvas.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CropCanvas.ViewModels"
        xmlns:controls="clr-namespace:CropCanvas.Controls"
        xmlns:converters="clr-namespace:CropCanvas.Converters"
        xmlns:res="clr-namespace:CropCanvas.Resources"
        Title="CropCanvas"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="500"
        Background="{StaticResource BaseBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
        <converters:NullToVisibilityConverter x:Key="NullVis"/>
        <FontFamily x:Key="TI">pack://application:,,,/Fonts/#tabler-icons</FontFamily>

        <!-- Scrollbar dark theme -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="MinWidth" Value="8"/>
        </Style>

        <!-- ComboBox: dark text on light background, including dropdown items -->
        <Style x:Key="ReadableCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#999"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#111111"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#D0D8F0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============ LEFT SIDEBAR ============ -->
        <Border Grid.Column="0" Background="{StaticResource MantleBrush}" Padding="10,10,10,8">
            <DockPanel>

                <!-- Folder buttons together at top -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button Command="{Binding SelectSourceFolderCommand}"
                            HorizontalAlignment="Stretch" Padding="10,8" Margin="0,0,0,4"
                            ToolTip="{Binding SourceFolderPath}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource TI}" Text="&#xeaad;"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock VerticalAlignment="Center" FontSize="14"
                                       Text="{Binding SourceFolderDisplay, FallbackValue='Bronmap selecteren'}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SelectOutputFolderCommand}"
                            HorizontalAlignment="Stretch" Padding="10,8"
                            ToolTip="{Binding OutputFolderPath}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource TI}" Text="&#xea96;"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock VerticalAlignment="Center" FontSize="14"
                                       Text="{Binding OutputFolderDisplay, FallbackValue='Output map selecteren'}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Image list: polaroid style -->
                <ListBox ItemsSource="{Binding Images}"
                         SelectedItem="{Binding SelectedImage}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="False"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Polaroid: white border, image top, name in white area below -->
                            <Grid Margin="4,4" Width="208">
                                <Border Background="#EEEEF2" CornerRadius="4"
                                        Padding="6,6,6,0" Effect="{x:Null}">
                                    <StackPanel>
                                        <Grid>
                                            <Image Source="{Binding Thumbnail}" Height="90"
                                                   Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <!-- Cropped badge -->
                                            <Border Background="{StaticResource GreenBrush}" CornerRadius="7"
                                                    Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,-2,-2,0"
                                                    Visibility="{Binding IsCropped, Converter={StaticResource BoolVis}}">
                                                <TextBlock FontFamily="{StaticResource TI}" Text="&#xea5e;"
                                                           FontSize="10" Foreground="#111"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding FileName}" FontSize="11"
                                                   Foreground="#444" FontFamily="Segoe UI"
                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,6" ToolTip="{Binding FileName}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="2" Margin="0,1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface0Brush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface0Brush}"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- SPLITTER -->
        <GridSplitter Grid.Column="1" Width="2" Background="{StaticResource Surface1Brush}"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <!-- ============ MAIN CONTENT ============ -->
        <DockPanel Grid.Column="2">

            <!-- TOP BAR: Ratio -->
            <Border DockPanel.Dock="Top" Background="{StaticResource MantleBrush}"
                    Padding="12,7" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Surface1Brush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.Ratio}" VerticalAlignment="Center" FontSize="14"
                               Margin="0,0,8,0" FontWeight="SemiBold"/>

                    <TextBlock VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"
                               Foreground="{StaticResource SubtextBrush}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}x{1}">
                                <Binding Path="ScreenResW"/>
                                <Binding Path="ScreenResH"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <TextBox Text="{Binding AspectRatioWidth, UpdateSourceTrigger=PropertyChanged}"
                             Width="38" VerticalAlignment="Center" FontSize="14" Padding="3,3"
                             IsEnabled="{Binding UseCustomAspectRatio}" TextAlignment="Center"/>
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="3,0" FontSize="14"/>
                    <TextBox Text="{Binding AspectRatioHeight, UpdateSourceTrigger=PropertyChanged}"
                             Width="38" VerticalAlignment="Center" FontSize="14" Padding="3,3"
                             IsEnabled="{Binding UseCustomAspectRatio}" TextAlignment="Center"/>

                    <!-- Lock/unlock toggle for custom ratio -->
                    <Button Command="{Binding ToggleCustomRatioCommand}"
                            Padding="6,4" Margin="6,0,0,0" ToolTip="{x:Static res:Strings.Custom}">
                        <TextBlock FontFamily="{StaticResource TI}" FontSize="18"
                                   Text="{Binding RatioLockIcon}"/>
                    </Button>

                    <Button Content="16:9" Command="{Binding SetPresetRatioCommand}" CommandParameter="16:9"
                            Padding="8,4" Margin="10,0,3,0" FontSize="13"/>
                    <Button Content="21:9" Command="{Binding SetPresetRatioCommand}" CommandParameter="21:9"
                            Padding="8,4" Margin="0,0,3,0" FontSize="13"/>
                    <Button Content="16:10" Command="{Binding SetPresetRatioCommand}" CommandParameter="16:10"
                            Padding="8,4" Margin="0,0,3,0" FontSize="13"/>
                    <Button Content="4:3" Command="{Binding SetPresetRatioCommand}" CommandParameter="4:3"
                            Padding="8,4" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- SECOND BAR: Format + AI -->
            <Border DockPanel.Dock="Top" Background="{StaticResource MantleBrush}"
                    Padding="12,6" BorderThickness="0,0,0,1" BorderBrush="{StaticResource Surface1Brush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{x:Static res:Strings.Format}" VerticalAlignment="Center" FontSize="14"
                               Margin="0,0,8,0" FontWeight="SemiBold"/>
                    <ComboBox Style="{StaticResource ReadableCombo}"
                              SelectedIndex="{Binding SelectedOutputFormat}" Width="75" Margin="0,0,20,0">
                        <ComboBoxItem Content="JPEG"/>
                        <ComboBoxItem Content="PNG"/>
                    </ComboBox>

                    <Rectangle Width="1" Fill="{StaticResource Surface1Brush}" Margin="0,2,12,2" Height="20"/>

                    <TextBlock FontFamily="{StaticResource TI}" Text="&#xf6d7;"
                               FontSize="16" Foreground="{StaticResource BlueBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{x:Static res:Strings.AI}" VerticalAlignment="Center" FontSize="14"
                               Margin="0,0,8,0" FontWeight="SemiBold"/>
                    <ComboBox Style="{StaticResource ReadableCombo}"
                              SelectedIndex="{Binding SelectedProvider}" Width="130" Margin="0,0,12,0">
                        <ComboBoxItem Content="Geen"/>
                        <ComboBoxItem Content="ComfyUI"/>
                        <ComboBoxItem Content="Stability AI"/>
                    </ComboBox>

                    <TextBlock Text="{x:Static res:Strings.ApiKey}" VerticalAlignment="Center" FontSize="13" Margin="0,0,6,0"
                               Visibility="{Binding IsStabilityProvider, Converter={StaticResource BoolVis}}"/>
                    <TextBox Text="{Binding StabilityApiKey, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" FontSize="13" Padding="6,4" VerticalAlignment="Center"
                             Visibility="{Binding IsStabilityProvider, Converter={StaticResource BoolVis}}"/>

                    <TextBlock Text="&#x1f310;" VerticalAlignment="Center" Margin="20,0,6,0" FontSize="16"/>
                    <ComboBox Style="{StaticResource ReadableCombo}" Width="55"
                              SelectedValue="{Binding SelectedLanguage}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="NL" Tag="nl"/>
                        <ComboBoxItem Content="EN" Tag="en"/>
                        <ComboBoxItem Content="DE" Tag="de"/>
                        <ComboBoxItem Content="FR" Tag="fr"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- BOTTOM: Status + centered Crop button -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource MantleBrush}"
                    Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="{StaticResource Surface1Brush}">
                <DockPanel>
                    <Button DockPanel.Dock="Top" Style="{StaticResource AccentButton}"
                            Command="{Binding CropCommand}" Padding="28,10"
                            HorizontalAlignment="Center" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <!-- AI sparkle icon when outpainting will be triggered -->
                            <TextBlock FontFamily="{StaticResource TI}" Text="&#xf6d7;"
                                       FontSize="18" Foreground="{StaticResource CrustBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                       Visibility="{Binding HasOutOfBounds, Converter={StaticResource BoolVis}}"/>
                            <TextBlock FontFamily="{StaticResource TI}" Text="&#xea85;"
                                       FontSize="18" Foreground="{StaticResource CrustBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding CropButtonText}" VerticalAlignment="Center" FontSize="15"
                                       Foreground="{StaticResource CrustBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource SubtextBrush}"
                               FontSize="13" HorizontalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- ============ IMAGE CANVAS ============ -->
            <Border Background="{StaticResource CrustBrush}">
                <Grid>
                    <!-- Zoom controls overlay (top-right) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,8,8,0" Panel.ZIndex="10">
                        <Button x:Name="BtnZoomOut" Padding="6,4" Margin="0,0,3,0" ToolTip="Zoom out (-)"
                                Click="OnZoomOut">
                            <TextBlock FontFamily="{StaticResource TI}" Text="&#xeb57;" FontSize="18"/>
                        </Button>
                        <Button x:Name="BtnZoomReset" Padding="6,4" Margin="0,0,3,0" ToolTip="Fit to window"
                                Click="OnZoomReset">
                            <TextBlock FontFamily="{StaticResource TI}" Text="&#xeaea;" FontSize="18"/>
                        </Button>
                        <Button x:Name="BtnZoom100" Padding="6,4" Margin="0,0,3,0" ToolTip="1:1 pixel"
                                Click="OnZoom100">
                            <TextBlock FontFamily="{StaticResource TI}" Text="&#xed30;" FontSize="18"/>
                        </Button>
                        <Button x:Name="BtnZoomIn" Padding="6,4" ToolTip="Zoom in (+)"
                                Click="OnZoomIn">
                            <TextBlock FontFamily="{StaticResource TI}" Text="&#xeb56;" FontSize="18"/>
                        </Button>
                        <TextBlock x:Name="ZoomLabel" Text="100%" FontSize="12"
                                   Foreground="{StaticResource SubtextBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <ScrollViewer x:Name="CanvasScroller"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="OnCanvasMouseWheel">
                        <Grid x:Name="ImageContainer"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.LayoutTransform>
                                <ScaleTransform x:Name="CanvasZoom" ScaleX="1" ScaleY="1"/>
                            </Grid.LayoutTransform>

                            <Image x:Name="MainImage"
                                   Source="{Binding DisplayImage}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                            <controls:CropOverlay
                                x:Name="CropOverlayControl"
                                AspectRatio="{Binding CropAspectRatio}"
                                NormalizedX="{Binding NormalizedCropX, Mode=TwoWay}"
                                NormalizedY="{Binding NormalizedCropY, Mode=TwoWay}"
                                NormalizedWidth="{Binding NormalizedCropWidth, Mode=TwoWay}"
                                NormalizedHeight="{Binding NormalizedCropHeight, Mode=TwoWay}"
                                HasOutOfBounds="{Binding HasOutOfBounds, Mode=TwoWay}"
                        AllowOutOfBounds="{Binding HasAIProvider}"
                        Visibility="{Binding DisplayImage, Converter={StaticResource NullVis}}"/>

                        </Grid>
                    </ScrollViewer>

                    <!-- Outpainting overlay outside scroll so it stays centered -->
                    <Border Background="#DD1E1E2E" CornerRadius="10"
                            Visibility="{Binding IsOutpainting, Converter={StaticResource BoolVis}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Padding="36,28" Panel.ZIndex="20">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="44" Height="44" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Border.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotation" CenterX="22" CenterY="22"/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                                 Storyboard.TargetProperty="Angle"
                                                                 From="0" To="360" Duration="0:0:1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <Ellipse Width="44" Height="44" StrokeThickness="4"
                                         Stroke="{StaticResource BlueBrush}"
                                         StrokeDashArray="2.5 1.5"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock FontFamily="{StaticResource TI}" Text="&#xf6d7;"
                                           FontSize="20" Foreground="{StaticResource BlueBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{x:Static res:Strings.AIOutpainting}"
                                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource SubtextBrush}"
                                       FontSize="14" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" MaxWidth="350"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DockPanel>
    </Grid>
</Window>
